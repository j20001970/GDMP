diff --git a/.bazelrc b/.bazelrc
--- a/.bazelrc
+++ b/.bazelrc
@@ -3,9 +3,6 @@
 # Tensorflow needs remote repo
 common --experimental_repo_remote_exec
 
-# WORKSPACE support
-common --noenable_bzlmod
-
 # Turn off toolchain resolution for cc rules and android rules.
 common --noincompatible_enable_cc_toolchain_resolution
 common --noincompatible_enable_android_toolchain_resolution
diff --git a/MODULE.bazel b/MODULE.bazel
new file mode 100644
--- /dev/null
+++ b/MODULE.bazel
@@ -0,0 +1,37 @@
+module(name = "mediapipe")
+
+bazel_dep(name = "rules_apple", version = "3.16.0", repo_name = "build_bazel_rules_apple")
+bazel_dep(name = "apple_support", version = "1.24.3", repo_name = "build_bazel_apple_support")
+
+bazel_dep(name = "rules_cc", version = "0.2.9")
+single_version_override(
+    module_name = "rules_cc",
+    version = "0.2.9",
+)
+bazel_dep(name = "rules_foreign_cc", version = "0.15.1")
+git_override(
+    module_name = "rules_foreign_cc",
+    remote = "https://github.com/bazel-contrib/rules_foreign_cc",
+    commit = "329140e4a0aef17dfc8e2907acd851e3d7d7a08c",
+)
+
+bazel_dep(name = "rules_python", version = "1.4.1", repo_name = "rules_python_bzlmod")
+single_version_override(
+    module_name = "rules_python",
+    version = "1.4.1",
+)
+
+# ABSL on 2025-01-23
+bazel_dep(name = "abseil-cpp", repo_name = "com_google_absl")
+archive_override(
+    module_name = "abseil-cpp",
+    strip_prefix = "abseil-cpp-20240116.3",
+    urls = ["https://github.com/abseil/abseil-cpp/archive/20240116.3.tar.gz"],
+)
+
+bazel_dep(name = "protobuf", repo_name = "com_google_protobuf")
+archive_override(
+    module_name = "protobuf",
+    strip_prefix = "protobuf-5.28.3",
+    urls = ["https://github.com/protocolbuffers/protobuf/archive/refs/tags/v5.28.3.zip"],
+)
